# ezBookkeeping Android Environment Variables
# Copy this file to .env and fill in actual values

# Server Configuration
EZR_SERVER_URL=https://your-server.example.com
EZR_API_VERSION=v1

# Authentication
EZR_JWT_SECRET=your_jwt_secret_here
EZR_TOTP_ISSUER=EZBookkeeping

# Database
EZR_DB_NAME=ezbk_database
EZR_DB_ENCRYPTION_KEY=your_encryption_key_here

# Exchange Rate Provider
EZR_EXCHANGE_RATE_PROVIDER=exchangerate_host
EZR_EXCHANGE_RATE_API_KEY=your_api_key_here

# Logging
EZR_LOG_LEVEL=INFO
EZR_ENABLE_NETWORK_LOG=true
